# Lidarr Unique Singles - Configuration

# Lidarr Connection
LIDARR_URL=http://192.168.10.34:8686
LIDARR_API_KEY=your_api_key_here

# Paths
LIDARR_MUSIC_PATH=/mnt/user/media/music
LOG_FILE=/var/log/lidarr-unique-singles.log

# Matching Criteria
DURATION_TOLERANCE_SECONDS=3
ARTIST_MATCH_MODE=exact
TITLE_MATCH_MODE=case_insensitive

# Release Types to Check (comma-separated)
RELEASE_TYPES_TO_CHECK=Album,EP

# Execution Mode
DRY_RUN=true
VERBOSE=false

# Safety
BACKUP_BEFORE_DELETE=false
BACKUP_PATH=/tmp/lidarr-unique-singles-backup